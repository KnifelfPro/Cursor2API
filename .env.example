# Local server port
PORT=3000

# Directory where the Cursor agent creates files (local / no-Docker use)
# Set this to your project directory so generated files appear there, not
# inside the proxy's own directory.
CURSOR_WORKDIR=/path/to/your/project

# Model used when the client does not specify one
# CURSOR_MODEL=default

# Embedding model and dimensions
# EMBEDDING_MODEL=text-embedding-3-small
# EMBEDDING_DIMENSIONS=1536

# Max request body size in bytes (default 1 MiB)
# MAX_BODY_BYTES=1048576
