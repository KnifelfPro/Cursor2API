{
  "name": "cursor2api-mcp",
  "version": "0.1.5",
  "license": "MIT",
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "bin": {
    "cursor2api-mcp": "src/mcp.js",
    "cursor2api-mcp-install": "scripts/install-mcp.mjs",
    "cursor2api-mcp-uninstall": "scripts/uninstall-mcp.mjs"
  },
  "files": [
    "scripts/install-mcp.cmd",
    "scripts/install-mcp.mjs",
    "scripts/install-mcp.sh",
    "scripts/uninstall-mcp.cmd",
    "scripts/uninstall-mcp.mjs",
    "scripts/uninstall-mcp.sh",
    "src/anthropic.js",
    "src/config.js",
    "src/core/cursor-runtime.js",
    "src/core/models.js",
    "src/errors.js",
    "src/handlers/anthropic.js",
    "src/handlers/chat.js",
    "src/handlers/completions.js",
    "src/handlers/embeddings.js",
    "src/handlers/models.js",
    "src/handlers/responses-api.js",
    "src/handlers/workspace.js",
    "src/http/request.js",
    "src/http/responses.js",
    "src/http/router.js",
    "src/logger.js",
    "src/mcp.js",
    "src/mcp/protocol.js",
    "src/mcp/routing.js",
    "src/mcp/stdio.js",
    "src/openai.js",
    "src/providers/anthropic.js",
    "src/providers/common.js",
    "src/providers/openai.js",
    "src/server.js",
    "README.md",
    "README.zh-CN.md",
    "LICENSE",
    "Dockerfile",
    "docker-compose.yml",
    ".dockerignore",
    ".env.example"
  ],
  "scripts": {
    "mcp": "node src/mcp.js",
    "start": "node --env-file-if-exists=.env src/server.js",
    "test": "node --test test/*.test.mjs"
  },
  "dependencies": {
    "@cursor/sdk": "1.0.21"
  }
}
